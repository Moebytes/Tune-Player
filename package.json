{
  "name": "tune-player",
  "version": "1.0.0",
  "author": "Moebytes",
  "description": "A cute music player!",
  "main": "dist/main/index.js",
  "scripts": {
    "start": "npm run clean && rsbuild build && electron dist/main/index.js",
    "build": "npm run clean ./build && rsbuild build && electron-builder -p never",
    "clean": "del-cli ./dist"
  },
  "keywords": [
    "music",
    "audio",
    "midi",
    "player",
    "anime",
    "cute"
  ],
  "repository": "https://github.com/Moebytes/Tune-Player",
  "privacyPolicy": "https://moebytes.com/privacy-policy",
  "license": "CC BY-NC 4.0",
  "build": {
    "appId": "com.moebytes.tune-player",
    "productName": "Tune Player",
    "directories": {
      "buildResources": "assets",
      "output": "build"
    },
    "mac": {
      "icon": "assets/mas/icon.icns",
      "target": {
        "target": "mas",
        "arch": "arm64"
      },
      "type": "distribution",
      "provisioningProfile": "assets/mas/MacAppStore.provisionprofile",
      "category": "public.app-category.music",
      "extraFiles": [
        "structures/bitcrusher.js",
        "structures/lfo.js",
        "structures/soundtouch.js"
      ]
    },
    "mas": {
      "entitlements": "assets/mas/entitlements.mas.plist",
      "entitlementsInherit": "assets/mas/entitlements.mas.inherit.plist"
    },
    "dmg": {
      "title": "Tune Player",
      "background": "./assets/background.png",
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "win": {
      "icon": "assets/appx/icon.icns",
      "target": {
          "target": "appx",
          "arch": "x64"
      },
      "extraFiles": [
        "structures/bitcrusher.js",
        "structures/lfo.js",
        "structures/soundtouch.js"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "uninstallDisplayName": "Tune Player",
      "createDesktopShortcut": "always",
      "installerSidebar": "./assets/installer.bmp",
      "uninstallerSidebar": "./assets/installer.bmp"
    },
    "appx": {
      "identityName": "Moebytes.TunePlayer",
      "publisher": "CN=4C1B763B-CF01-4978-8749-986F562173D8",
      "publisherDisplayName": "Moebytes",
      "capabilities": [
          "runFullTrust", 
          "internetClient",
          "extendedExecutionBackgroundAudio"
      ]
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": {
        "target": "AppImage",
        "arch": "x64"
      },
      "category": "Audio",
      "extraFiles": [
        "structures/bitcrusher.js",
        "structures/lfo.js",
        "structures/soundtouch.js"
      ]
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "fileAssociations": [
      {
        "ext": "mp3",
        "description": "Audio files"
      },
      {
        "ext": "wav",
        "description": "Audio files"
      },
      {
        "ext": "ogg",
        "description": "Audio files"
      },
      {
        "ext": "flac",
        "description": "Audio files"
      },
      {
        "ext": "aac",
        "description": "Audio files"
      },
      {
        "ext": "mid",
        "description": "MIDI files"
      }
    ]
  },
  "devDependencies": {
    "@electron-rsbuild/plugin-main": "^0.0.12",
    "@electron-rsbuild/plugin-preload": "^0.0.12",
    "@electron-rsbuild/plugin-renderer": "^0.0.12",
    "@rsbuild/core": "^1.7.3",
    "@rsbuild/plugin-less": "^1.6.0",
    "@rsbuild/plugin-node-polyfill": "^1.4.4",
    "@rsbuild/plugin-react": "^1.4.5",
    "@rsbuild/plugin-type-check": "^1.3.3",
    "@svgr/webpack": "^8.1.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "del-cli": "^7.0.0",
    "electron": "^40.4.1",
    "electron-builder": "^26.8.1",
    "node-loader": "^2.1.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@electron/osx-sign": "^2.3.0",
    "@reduxjs/toolkit": "^2.11.2",
    "@tonejs/midi": "^2.0.28",
    "audio-encoder": "^1.0.2",
    "bootstrap": "^5.3.8",
    "browser-id3-writer": "^6.3.1",
    "electron-click-drag-plugin": "^2.0.2",
    "electron-localshortcut": "^3.2.1",
    "electron-store": "^8.0.0",
    "jsmediatags": "^3.9.7",
    "music-metadata": "^11.12.1",
    "react": "^19.2.4",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.2.4",
    "react-redux": "^9.2.0",
    "react-slider": "github:Moestash/react-slider",
    "soundcloud.ts": "^0.7.2",
    "tone": "^14.7.39",
    "web-audio-beat-detector": "^8.2.35",
    "youtube.ts": "^0.3.5"
  }
}
